# Swindle V1 environment example
# Copy to .env for local development. Replace every placeholder before deployment.

# App
APP_NAME=Swindle
APP_ENV=development
APP_DEBUG=false
APP_SECRET_KEY=replace-with-random-secret
JWT_SECRET_KEY=replace-with-random-secret
FRONTEND_ORIGIN=http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
BACKEND_ORIGIN=http://127.0.0.1:8000

# Database
DATABASE_URL=postgresql+psycopg://swindle:swindle@localhost:5432/swindle

# Redis / worker placeholder for later background jobs
REDIS_URL=redis://localhost:6379/0

# Lichess OAuth
LICHESS_CLIENT_ID=replace-with-lichess-client-id
LICHESS_REDIRECT_URI=http://127.0.0.1:8000/api/v1/integrations/lichess/callback
LICHESS_SCOPES=preference:read
LICHESS_OAUTH_AUTHORIZE_URL=https://lichess.org/oauth
LICHESS_OAUTH_TOKEN_URL=https://lichess.org/api/token
LICHESS_API_BASE_URL=https://lichess.org

# Token encryption
# Generate a Fernet key, for example:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=replace-with-fernet-key

# Frontend build
VITE_API_BASE=http://127.0.0.1:8000/api/v1
